{
  "manifest_version": 3,
  "name": "ChatGPT Web Bridge MVP",
  "version": "0.1.0",
  "description": "Удаленный browser-agent для отправки промптов в ChatGPT Web через выделенные вкладки браузера.",
  "permissions": ["tabs", "storage"],
  "host_permissions": ["https://chatgpt.com/*", "http://*/*", "https://*/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; connect-src http://127.0.0.1:* ws://127.0.0.1:* http://localhost:* ws://localhost:* https: wss:;"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "ChatGPT Web Bridge",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "chatgpt-web-bridge@example.local",
      "strict_min_version": "121.0"
    }
  }
}
